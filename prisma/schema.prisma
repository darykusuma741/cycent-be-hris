// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  employee  Employee?
  leaves    Leave[]
}

model Employee {
  id                Int                @id @default(autoincrement())
  name              String
  position          String?
  userId            Int?               @unique // <-- masih optional
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  salary            Int
  allowances        Int
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendances       Attendance[]
  shiftAssignments  ShiftAssignment[]
  officeAssignments OfficeAssignment[]
  leaves            Leave[]
  attendanceSheets  AttendanceSheet[]
  payrolls          Payroll[]
}

model Attendance {
  id                Int       @id @default(autoincrement())
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId        Int
  date              DateTime
  checkInStatus     String?   @default("Present") // "Present", "Sick", "Permission", "Leave"
  checkOutStatus    String?
  checkIn           DateTime?
  checkInLatitude   Float? // optional latitude at check-in
  checkInLongitude  Float? // optional longitude at check-in
  checkOut          DateTime?
  checkOutLatitude  Float? // optional latitude at check-out
  checkOutLongitude Float? // optional longitude at check-out

  // ✨ new fields for estimated hours
  checkInHours           Float? // EARLY/LATE hours
  checkInHoursFormatter  String? // formatted string for check-in hours (e.g., "1h 30m")
  checkOutHours          Float? // LEFT_EARLY/OVERTIME hours
  checkOutHoursFormatted String? // formatted string for check-out hours (e.g., "1h 30m")

  notes            String?
  shiftId          Int?
  shift            Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  checkInOfficeId  Int?
  checkInOffice    OfficeLocation? @relation("CheckInOffice", fields: [checkInOfficeId], references: [id], onDelete: SetNull)
  checkOutOfficeId Int?
  checkOutOffice   OfficeLocation? @relation("CheckOutOffice", fields: [checkOutOfficeId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([employeeId, date]) // Ensure one record per employee per day
}

model Shift {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  startTime        String
  endTime          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shiftAssignments ShiftAssignment[]
  attendances      Attendance[]
}

model ShiftAssignment {
  id            Int      @id @default(autoincrement())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId    Int
  shift         Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId       Int
  startDateTime DateTime // Waktu mulai shift, termasuk tanggal
  endDateTime   DateTime // Waktu selesai shift, termasuk tanggal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, startDateTime]) // Pastikan satu shift per employee per periode
}

model OfficeLocation {
  id                  Int                @id @default(autoincrement())
  name                String             @unique
  latitude            Float
  longitude           Float
  radius              Float // in meters
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  officeAssignments   OfficeAssignment[]
  checkInAttendances  Attendance[]       @relation("CheckInOffice")
  checkOutAttendances Attendance[]       @relation("CheckOutOffice")
}

model OfficeAssignment {
  id               Int            @id @default(autoincrement())
  employee         Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId       Int
  officeLocation   OfficeLocation @relation(fields: [officeLocationId], references: [id], onDelete: Cascade)
  officeLocationId Int
  date             DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([employeeId, date]) // Ensure one office assignment per employee per day
}

model Leave {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  leaveType  String // misal: "Sick", "Annual", "Permission", "Unpaid"
  startDate  DateTime // tanggal mulai cuti
  endDate    DateTime // tanggal selesai cuti
  totalDays  Float? // durasi cuti dalam hari (opsional, bisa dihitung otomatis)
  reason     String? // alasan cuti
  status     String   @default("Pending") // Pending, Approved, Rejected
  approvedBy Int? // FK ke User yang menyetujui
  approver   User?    @relation(fields: [approvedBy], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

model LeavePolicy {
  id          Int      @id @default(autoincrement())
  leaveType   String   @unique
  annualQuota Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendancePeriod {
  id        Int      @id @default(autoincrement())
  name      String // contoh: "March 2026"
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false) // kalau sudah diproses payroll

  attendanceSheets AttendanceSheet[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payrollPeriods PayrollPeriod[]

  @@unique([startDate, endDate])
}

model AttendanceSheet {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  periodId Int
  period   AttendancePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  absentDates        String @default("")
  totalPresent       Int    @default(0)
  totalLate          Int    @default(0)
  totalEarlyLeave    Int    @default(0)
  totalOvertime      Float  @default(0)
  totalNotCheckedOut Int    @default(0)

  totalLeaveDays  Float @default(0)
  totalAbsentDays Float @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payrolls  Payroll[]

  @@unique([employeeId, periodId])
}

model PayrollPeriod {
  id                 Int              @id @default(autoincrement())
  name               String // Maret 2026
  startDate          DateTime
  endDate            DateTime
  isClosed           Boolean          @default(false) // kalau sudah diproses payroll
  attendancePeriodId Int
  attendancePeriod   AttendancePeriod @relation(fields: [attendancePeriodId], references: [id], onDelete: Cascade)

  payrolls Payroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payroll {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  payrollPeriodId Int
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)

  attendanceSheetId Int?
  attendanceSheet   AttendanceSheet? @relation(fields: [attendanceSheetId], references: [id], onDelete: SetNull)

  // Komponen gaji
  basicSalary Float // gaji pokok
  allowances  Float @default(0) // tunjangan
  deductions  Float @default(0) // potongan, misal bolos, terlambat, atau pinjaman
  overtimePay Float @default(0) // lembur
  netSalary   Float // gaji bersih = basic + allowance + overtime - deductions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, payrollPeriodId])
}
